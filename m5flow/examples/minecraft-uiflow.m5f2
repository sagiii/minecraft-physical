ed=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">1500</field></shadow></value><value name=\"MS\"><shadow type=\"math_number\" id=\"lf]XyqIm=hZiX3jB.x)C\" disabled=\"true\"><mutation max=\"Infinity\" min=\"-Infinity\" precision=\"0\"></mutation><field name=\"NUM\">50</field></shadow></value></block></next></block></statement></block></statement></block></next></block></statement></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":135,"height":240,"scale":0.67,"screenName":"","blockId":"","screenColorType":0,"rotation":1,"id":"builtin","createTime":1775270628264}],"logicWhenNum":3,"customList":[{"id":"custom_minecraftbridge","name":"MinecraftBridge","color":"#0fb1d2","blockly":"const CUSTOM_MINECRAFTBRIDGE_LANGUAGES = {\n  \"CUSTOM_MINECRAFTBRIDGE_INIT\": {\n    \"en\": \"%1 init\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_CONNECT\": {\n    \"en\": \" %1 connect, broker_ip: %2, broker_port: %3, ssid: %4, password: %5\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_SEND\": {\n    \"en\": \" %1 send, channel: %2, value: %3\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_GET_VALUE\": {\n    \"en\": \" %1 get_value, channel: %2\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_ON_CHANNEL\": {\n    \"en\": \" %1 on_channel, channel: %2, callback: %3\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_ON_CHANNEL_VALUE\": {\n    \"en\": \" %1 on_channel_value, channel: %2, value: %3, callback: %4\"\n  },\n  \"CUSTOM_MINECRAFTBRIDGE_CHECK\": {\n    \"en\": \" %1 check\"\n  }\n};\n\nconst initType = 'custom_minecraftbridge_init';\nBlockly.BlockRegExpList['custom_minecraftbridge'] = {\n  regexp: new RegExp(/^custom_minecraftbridge_/),\n  code: \"from MinecraftBridge import MinecraftBridge\",\n  initBlockType: initType,\n  categoryId: 'custom_minecraftbridge',\n}\nBlockly.utils.registerLanguages(CUSTOM_MINECRAFTBRIDGE_LANGUAGES)\n\nBlockly.Msg.CUSTOM_MINECRAFTBRIDGE_HUE = '#0fb1d2'\nBlockly.Msg.CUSTOM_MINECRAFTBRIDGE = 'MinecraftBridge'\n\nBlockly.utils.getcustom_minecraftbridgeOptions = function() {\n  let options = [];\n  let list = Blockly.utils.getCustomNameList(initType);\n  for (let i = 0; i < list.length; i++) {\n    let value = list[i];\n    options.push([String(value), String(value)]);\n  }\n  if (options.length === 0) return [\n    ['minecraftbridge_0', 'minecraftbridge_0']\n  ];\n  return options;\n}\n\n\nBlockly.Blocks[\"custom_minecraftbridge_init\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_INIT,\n      'args0': [\n        // { 'type': 'field_dropdown', 'name': 'NAME', 'options': Blockly.utils.getcustom_minecraftbridgeOptions },\n        {\n          'type': 'field_input',\n          'name': 'NAME',\n          'text': 'minecraftbridge_0'\n        },\n\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n      \"tool\": []\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_init\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n\n  return `${varname} = MinecraftBridge()\\n`\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_connect\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_CONNECT,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'broker_ip'\n        }, {\n          'type': 'input_value',\n          'name': 'broker_port'\n        }, {\n          'type': 'input_value',\n          'name': 'ssid'\n        }, {\n          'type': 'input_value',\n          'name': 'password'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_connect\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var broker_ip = Blockly.Python.valueToCode(block, 'broker_ip', Blockly.Python.ORDER_FUNCTION_CALL);\n  var broker_port = Blockly.Python.valueToCode(block, 'broker_port', Blockly.Python.ORDER_FUNCTION_CALL);\n  var ssid = Blockly.Python.valueToCode(block, 'ssid', Blockly.Python.ORDER_FUNCTION_CALL);\n  var password = Blockly.Python.valueToCode(block, 'password', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.connect(${broker_ip}, ${broker_port}, ${ssid}, ${password})\\n`\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_send\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_SEND,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'channel'\n        }, {\n          'type': 'input_value',\n          'name': 'value'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_send\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var channel = Blockly.Python.valueToCode(block, 'channel', Blockly.Python.ORDER_FUNCTION_CALL);\n  var value = Blockly.Python.valueToCode(block, 'value', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.send(${channel}, ${value})\\n`\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_get_value\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_GET_VALUE,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'channel'\n        },\n      ],\n      'output': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_get_value\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var channel = Blockly.Python.valueToCode(block, 'channel', Blockly.Python.ORDER_FUNCTION_CALL);\n  return [`${varname}.get_value(${channel})`, Blockly.Python.ORDER_NONE]\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_on_channel\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_ON_CHANNEL,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'channel'\n        }, {\n          'type': 'input_value',\n          'name': 'callback'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_on_channel\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var channel = Blockly.Python.valueToCode(block, 'channel', Blockly.Python.ORDER_FUNCTION_CALL);\n  var callback = Blockly.Python.valueToCode(block, 'callback', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.on_channel(${channel}, ${callback})\\n`\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_on_channel_value\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_ON_CHANNEL_VALUE,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n        {\n          'type': 'input_value',\n          'name': 'channel'\n        }, {\n          'type': 'input_value',\n          'name': 'value'\n        }, {\n          'type': 'input_value',\n          'name': 'callback'\n        },\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_on_channel_value\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n  var channel = Blockly.Python.valueToCode(block, 'channel', Blockly.Python.ORDER_FUNCTION_CALL);\n  var value = Blockly.Python.valueToCode(block, 'value', Blockly.Python.ORDER_FUNCTION_CALL);\n  var callback = Blockly.Python.valueToCode(block, 'callback', Blockly.Python.ORDER_FUNCTION_CALL);\n  return `${varname}.on_channel_value(${channel}, ${value}, ${callback})\\n`\n}\n\nBlockly.Blocks[\"custom_minecraftbridge_check\"] = {\n  init: function() {\n    this.jsonInit(this._init());\n  },\n  _init: function() {\n    return {\n      'message0': Blockly.Msg.CUSTOM_MINECRAFTBRIDGE_CHECK,\n      'args0': [{\n          'type': 'field_dropdown',\n          'name': 'NAME',\n          'options': Blockly.utils.getcustom_minecraftbridgeOptions\n        },\n\n      ],\n      'previousStatement': null,\n      'nextStatement': null,\n      'inputsInline': true,\n      'colour': \"#0fb1d2\",\n    };\n  }\n}\n\nBlockly.Python[\"custom_minecraftbridge_check\"] = function(block) {\n  var varname = block.getFieldValue('NAME') || '_';\n\n  return `${varname}.check()\\n`\n}","toolbox":"\n<category name=\"MinecraftBridge\" colour=\"#0fb1d2\" hidden=\"true\" toolboxitemid=\"custom_minecraftbridge\">\n<title text=\"MinecraftBridge\" docsLink=\"\"></title>\n<block type=\"custom_minecraftbridge_init\"/><block type=\"custom_minecraftbridge_connect\">\n  <value name=\"broker_ip\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n  <value name=\"broker_port\">\n    <shadow type=\"math_number\">\n      <field name=\"NUM\">1883</field>\n    </shadow>\n  </value>\n  <value name=\"ssid\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\">None</field>\n    </shadow>\n  </value>\n  <value name=\"password\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\">None</field>\n    </shadow>\n  </value>\n</block><block type=\"custom_minecraftbridge_send\">\n  <value name=\"channel\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n  <value name=\"value\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n</block><block type=\"custom_minecraftbridge_get_value\">\n  <value name=\"channel\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n</block><block type=\"custom_minecraftbridge_on_channel\">\n  <value name=\"channel\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n  <value name=\"callback\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n</block><block type=\"custom_minecraftbridge_on_channel_value\">\n  <value name=\"channel\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n  <value name=\"value\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n  <value name=\"callback\">\n    <shadow type=\"text\">\n      <field name=\"TEXT\"/>\n    </shadow>\n  </value>\n</block><block type=\"custom_minecraftbridge_check\"/>\n</category>\n","pyCode":"\n\"\"\"\nfile     MinecraftBridge\ntime     2026-04-04\nauthor   \nemail   \nlicense  \n\"\"\"\n\nimport sys\nsys.path.append('/flash')\nfrom libs.minecraft_mqtt import MqttBridge as _Bridge\n\nclass MinecraftBridge:\n    \"\"\"\n    note: ''\n    details:\n        color: '#0fb1d2'\n        link: ''\n        image: ''\n        category: Custom\n    example: ''\n    \"\"\"\n\n\n\n\n    def __init__(self):\n        \"\"\"\n        label:\n            en: '%1 init'\n        \"\"\"\n        self._bridge = None\n\n    def connect(self, broker_ip, broker_port: int = 1883, ssid = None, password = None):\n        \"\"\"\n        label:\n            en: ' %1 connect, broker_ip: %2, broker_port: %3, ssid: %4, password: %5'\n        params:\n            broker_ip:\n                name: broker_ip\n            broker_port:\n                name: broker_port\n                type: int\n                default: '1883'\n            ssid:\n                name: ssid\n                default: None\n            password:\n                name: password\n                default: None\n        \"\"\"\n        import network\n        self._bridge = _Bridge(broker_ip, broker_port)\n        if ssid and password:\n            self._bridge.connect_wifi(ssid, password)\n        elif not network.WLAN(network.STA_IF).isconnected():\n            raise RuntimeError('[Minecraft] WiFi not connected. Provide ssid and password.')\n        self._bridge.connect_mqtt()\n\n    def send(self, channel, value):\n        \"\"\"\n        label:\n            en: ' %1 send, channel: %2, value: %3'\n        params:\n            channel:\n                name: channel\n            value:\n                name: value\n        \"\"\"\n        if self._bridge:\n            self._bridge.send(int(channel), bool(value))\n\n    def get_value(self, channel):\n        \"\"\"\n        label:\n            en: ' %1 get_value, channel: %2'\n        params:\n            channel:\n                name: channel\n        \"\"\"\n        if self._bridge:\n            return self._bridge.get_value(int(channel))\n        return False\n\n    def on_channel(self, channel, callback):\n        \"\"\"\n        label:\n            en: ' %1 on_channel, channel: %2, callback: %3'\n        params:\n            channel:\n                name: channel\n            callback:\n                name: callback\n        \"\"\"\n        if self._bridge:\n            self._bridge.on_channel(int(channel), callback)\n\n    def on_channel_value(self, channel, value, callback):\n        \"\"\"\n        label:\n            en: ' %1 on_channel_value, channel: %2, value: %3, callback: %4'\n        params:\n            channel:\n                name: channel\n            value:\n                name: value\n            callback:\n                name: callback\n        \"\"\"\n        if self._bridge:\n            expected = bool(value)\n            self._bridge.on_channel(int(channel), lambda v: callback() if v == expected else None)\n\n    def check(self):\n        \"\"\"\n        label:\n            en: ' %1 check'\n        \"\"\"\n        if self._bridge:\n            self._bridge.check()\n\n\n"}]}